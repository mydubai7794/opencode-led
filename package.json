{
  "name": "ai-led-light",
  "version": "0.1.0",
  "description": "AI coding assistant LED indicator - MQTT event bridge",
  "type": "module",
  "scripts": {
    "broker": "node broker.js",
    "subscribe": "node subscriber.js",
    "test": "node test-publisher.js",
    "start": "node broker.js & sleep 1 && node subscriber.js & sleep 1 && node test-publisher.js",
    "daemon:start": "node claude-led-daemon.mjs",
    "daemon:stop": "node -e \"const http=require('http');const port=require('fs').readFileSync(require('os').tmpdir()+'/claude-led-daemon.port','utf-8').trim()||4578;const r=http.request({hostname:'127.0.0.1',port:+port,path:'/shutdown',method:'POST'},()=>{console.log('Daemon stopped');process.exit(0)});r.on('error',()=>{console.log('Daemon not running');process.exit(1)});r.end()\"",
    "daemon:status": "node -e \"const port=require('fs').readFileSync(require('os').tmpdir()+'/claude-led-daemon.port','utf-8').trim()||4578;require('http').get('http://127.0.0.1:'+port+'/health',(r)=>{let d='';r.on('data',c=>d+=c);r.on('end',()=>console.log(JSON.parse(d)))}).on('error',()=>console.log('Daemon not running'))\""
  },
  "dependencies": {
    "aedes": "^0.51.0",
    "mqtt": "^5.10.4",
    "selfsigned": "^5.5.0",
    "serialport": "^13.0.0"
  }
}
